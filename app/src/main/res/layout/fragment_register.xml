<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true"
    android:padding="24dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Efek Lampu Gradasi Ungu Accent di Background (Sudah Aman) -->
        <View
            android:layout_width="300dp"
            android:layout_height="300dp"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="50dp"
            android:background="@drawable/bg_glass_card"
            android:alpha="0.08" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:orientation="vertical"
            android:background="@drawable/bg_glass_card"
            android:padding="24dp"
            android:elevation="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="INITIALIZE IDENTITY"
                android:textColor="@color/accent_purple"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.2" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Register Node"
                android:textColor="@color/text_white"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="20dp" />

            <!-- Input Username -->
            <EditText
                android:id="@+id/etRegisterUsername"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_glass_card"
                android:hint="Create username..."
                android:inputType="text"
                android:paddingHorizontal="16dp"
                android:textColor="@color/text_white"
                android:textColorHint="@color/text_muted"
                android:textSize="14sp"
                android:layout_marginBottom="12dp" />

            <!-- Input Gmail -->
            <EditText
                android:id="@+id/etRegisterGmail"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_glass_card"
                android:hint="Create node email address..."
                android:inputType="textEmailAddress"
                android:paddingHorizontal="16dp"
                android:textColor="@color/text_white"
                android:textColorHint="@color/text_muted"
                android:textSize="14sp"
                android:layout_marginBottom="12dp" />

            <!-- Input Password -->
            <EditText
                android:id="@+id/etRegisterPassword"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_glass_card"
                android:hint="Create master password..."
                android:inputType="textPassword"
                android:paddingHorizontal="16dp"
                android:textColor="@color/text_white"
                android:textColorHint="@color/text_muted"
                android:textSize="14sp"
                android:layout_marginBottom="12dp" />

            <!-- Input Ulang Password -->
            <EditText
                android:id="@+id/etRegisterConfirmPassword"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_glass_card"
                android:hint="Repeat master password..."
                android:inputType="textPassword"
                android:paddingHorizontal="16dp"
                android:textColor="@color/text_white"
                android:textColorHint="@color/text_muted"
                android:textSize="14sp"
                android:layout_marginBottom="20dp" />

            <!-- Tombol Register Submit -->
            <Button
                android:id="@+id/btnRegisterSubmit"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Compile &amp; Register"
                android:textColor="@color/text_white"
                android:textStyle="bold"
                android:backgroundTint="@color/accent_purple"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:cornerRadius="12dp"
                android:layout_marginBottom="12dp" />

            <!-- Tombol Kembali ke Login -->
            <Button
                android:id="@+id/btnToLogin"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Already have node? Sign In"
                android:textColor="@color/text_muted"
                android:backgroundTint="@android:color/transparent"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:strokeColor="@color/stroke_glass"
                app:strokeWidth="1dp"
                app:cornerRadius="12dp" />
        </LinearLayout>
    </RelativeLayout>
</ScrollView>