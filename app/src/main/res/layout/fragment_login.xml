<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:padding="24dp">

    <!-- Efek Lampu Gradasi / Ambient Glow di Background (Sudah Diperbaiki) -->
    <View
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="-100dp"
        android:background="@drawable/bg_glass_card"
        android:alpha="0.1" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:orientation="vertical"
        android:background="@drawable/bg_glass_card"
        android:padding="24dp"
        android:elevation="8dp">

        <!-- Header Brand -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VELORA CORE"
            android:textColor="@color/accent_blue"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.2" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome Back"
            android:textColor="@color/text_white"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="24dp" />

        <!-- Input Gmail -->
        <EditText
            android:id="@+id/etLoginGmail"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_glass_card"
            android:hint="Enter your node email..."
            android:inputType="textEmailAddress"
            android:paddingHorizontal="16dp"
            android:textColor="@color/text_white"
            android:textColorHint="@color/text_muted"
            android:textSize="14sp"
            android:layout_marginBottom="12dp" />

        <!-- Input Password -->
        <EditText
            android:id="@+id/etLoginPassword"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_glass_card"
            android:hint="Enter secure password..."
            android:inputType="textPassword"
            android:paddingHorizontal="16dp"
            android:textColor="@color/text_white"
            android:textColorHint="@color/text_muted"
            android:textSize="14sp"
            android:layout_marginBottom="20dp" />

        <!-- Tombol Login (Solid Accent) -->
        <Button
            android:id="@+id/btnLoginSubmit"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Sign In To Ecosystem"
            android:textColor="@color/text_white"
            android:textStyle="bold"
            android:backgroundTint="@color/accent_blue"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:cornerRadius="12dp"
            android:layout_marginBottom="12dp" />

        <!-- Tombol navigasi ke Register -->
        <Button
            android:id="@+id/btnToRegister"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Create New Account Node"
            android:textColor="@color/text_muted"
            android:backgroundTint="@android:color/transparent"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:strokeColor="@color/stroke_glass"
            app:strokeWidth="1dp"
            app:cornerRadius="12dp" />
    </LinearLayout>
</RelativeLayout>