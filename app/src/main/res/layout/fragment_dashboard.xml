<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#09090B"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_centerInParent="true">

        <TextView
            android:id="@+id/tvWelcomeDashboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Welcome Back, User!\nVelora System Operational."
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Use the bottom navigation to manage your ecosystem cores and gallery parameters."
            android:textColor="#A1A1AA"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginTop="12dp" />

    </LinearLayout>
</RelativeLayout>