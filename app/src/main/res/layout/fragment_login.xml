<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#09090B"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Lumaro Gallery"
        android:textColor="#2563EB"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Connect your node to the ecosystem"
        android:textColor="#71717A"
        android:textSize="14sp"
        android:layout_marginBottom="32dp"/>

    <EditText
        android:id="@+id/etLoginGmail"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="#121214"
        android:hint="Gmail Address"
        android:textColorHint="#52525B"
        android:textColor="#FFFFFF"
        android:paddingHorizontal="16dp"
        android:inputType="textEmailAddress"
        android:layout_marginBottom="12dp"/>

    <EditText
        android:id="@+id/etLoginPassword"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="#121214"
        android:hint="Password"
        android:textColorHint="#52525B"
        android:textColor="#FFFFFF"
        android:paddingHorizontal="16dp"
        android:inputType="textPassword"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btnLoginSubmit"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Authorize Login"
        android:backgroundTint="#2563EB"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tvToRegister"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="New Architect? Create an account node"
        android:textColor="#A1A1AA"
        android:textSize="13sp"/>
</LinearLayout>